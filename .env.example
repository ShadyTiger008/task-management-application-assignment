# ==============================================================================
# BACKEND CONFIGURATION (NestJS)
# ==============================================================================
BACKEND_DB_CONNECTION="postgresql://<username>:<password>@<host>:<port>/<database>?sslmode=require"
BACKEND_DATABASE_URL="postgresql://<username>:<password>@<host>:<port>/<database>?sslmode=require"
BACKEND_JWT_SECRET="your-32-character-or-longer-access-token-secret"
BACKEND_JWT_REFRESH_SECRET="your-32-character-or-longer-refresh-token-secret"
BACKEND_PORT=3001

# ==============================================================================
# FRONTEND CONFIGURATION (Next.js)
# ==============================================================================
# Add any Next.js environment variables here if required by frontend src/env.js
NEXT_PUBLIC_API_URL="http://localhost:3001"
