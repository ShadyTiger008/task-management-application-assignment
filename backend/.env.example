# Database connection string
DB_CONNECTION="postgresql://<username>:<password>@<host>:<port>/<database>?sslmode=require"
DATABASE_URL="postgresql://<username>:<password>@<host>:<port>/<database>?sslmode=require"

# JWT Secret keys
JWT_SECRET="your-32-character-or-longer-access-token-secret"
JWT_REFRESH_SECRET="your-32-character-or-longer-refresh-token-secret"

# Port mapping
PORT=3001

# ==============================================================================
# OPTIONAL INTEGRATIONS (AI & AVATARS)
# ==============================================================================
# Unsplash access key for random avatar generation
UNSPLASH_ACCESS_KEY="your-unsplash-access-key-here"

# Groq API key for AI-powered description generation (Primary)
GROQ_API_KEY="your-groq-api-key-here"

# OpenRouter API key for AI-powered description generation (Fallback)
OPENROUTER_API_KEY="your-openrouter-api-key-here"

# Cloudinary Integration for file uploads
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
